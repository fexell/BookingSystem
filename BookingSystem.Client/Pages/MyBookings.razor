@page "/mybookings"
@using Microsoft.AspNetCore.Authorization
@using BookingSystem.Shared.DTOs
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory

<h3>Mina Bokningar</h3>
<hr />

@if (bookings == null)
{
    <p><em>Laddar dina bokningar...</em></p>
}
else if (bookings.Count == 0)
{
    <div class="alert alert-info">Du har inga aktiva bokningar just nu. (Eller så kunde de inte hämtas från databasen).</div>
}
else
{
    <div class="row">
        @foreach (var booking in bookings)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">Bokning #@booking.Id</h5>
                        
                        <h6 class="card-subtitle mb-2 text-muted">
                            @booking.StartTime.ToString("yyyy-MM-dd kl. HH:mm") - @booking.EndTime.ToString("HH:mm")
                        </h6>
                        
                        <p class="card-text mt-3">
                            Status:
                            @if (booking.Status == "Bekräftad" || booking.Status == "Confirmed")
                            {
                                <span class="badge bg-success">Bekräftad</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">@booking.Status</span>
                            }
                        </p>
                    </div>
                    <div class="card-footer bg-transparent border-top-0">
                        <button class="btn btn-outline-danger btn-sm w-100"
                                @onclick="() => CancelBooking(booking.Id)">
                            Avboka
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<BookingDto>? bookings;

    protected override async Task OnInitializedAsync()
    {
        await LoadBookings();
    }

    private async Task LoadBookings()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("API");
            
            // Gör anropet och kolla vad backend faktiskt svarar
            var response = await client.GetAsync("api/bookings/user/me");

            if (response.IsSuccessStatusCode)
            {
                bookings = await response.Content.ReadFromJsonAsync<List<BookingDto>>() ?? new List<BookingDto>();
            }
            else
            {
                // Om backend klagar, skriv ut EXAKT varför i webbläsarens konsol
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"FEL FRÅN BACKEND: Status {response.StatusCode}. Detaljer: {error}");
                bookings = new List<BookingDto>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"KUNDE INTE NÅ API: {ex.Message}");
            bookings = new List<BookingDto>();
        }
    }

    private async Task CancelBooking(int id)
    {
        try
        {
            var client = HttpClientFactory.CreateClient("API");
            var response = await client.DeleteAsync($"api/bookings/{id}");
            
            if (response.IsSuccessStatusCode)
            {
                await LoadBookings();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Kunde inte avboka. API svarade: {error}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Kunde inte avboka pga systemfel: {ex.Message}");
        }
    }
}