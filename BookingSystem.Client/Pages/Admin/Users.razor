@page "/admin/users"
@using System.ComponentModel.DataAnnotations
@using BookingSystem.Shared.DTOs
@using BookingSystem.Client.Services
@inject HttpClient Http
@inject UserService UserService

<div class="users-page">
    <div class="users-header">
        <h1 class="users-title">Admin – Users</h1>
        <p class="users-subtitle">Manage all users in the system</p>
    </div>

    @if ( users is null ) {
        <div class="users-grid">
            @for ( int i = 0; i < 6; i++ ) {
                <div class="user-card skeleton-card">
                    <div class="card-avatar skeleton-avatar"></div>
                    <div class="card-body">
                        <div class="skeleton-line skeleton-title"></div>
                        <div class="skeleton-line skeleton-text"></div>
                        <div class="skeleton-line skeleton-text short"></div>
                    </div>
                </div>
            }
        </div>
    } else if ( !users.Any() ) {
        <div class="empty-state">
            <div class="empty-icon">👤</div>
            <p>No users found.</p>
        </div>
    } else {
        <div class="users-grid">
            @foreach ( var user in users ) {
                <div class="user-card @(user.Role == "Admin" ? "role-admin" : "role-user")">
                    <div class="card-avatar-section">
                        <div class="card-avatar-placeholder">
                            <span class="user-initial">@user.FirstName[ 0 ]</span>
                        </div>
                        <span class="role-badge @(user.Role == "Admin" ? "badge-admin" : "badge-user")">
                            @user.Role
                        </span>
                    </div>

                    <div class="card-body">
                        <h2 class="card-title">@user.FirstName @user.Surname</h2>
                        <p class="card-username">@@@user.Username</p>
                        <p class="card-email">@user.Email</p>
                    </div>

                    <div class="card-footer admin-actions">
                        <button class="btn-edit" @onclick="() => OpenEditModal( user )">Edit</button>
                        <button class="btn-delete" @onclick="() => OpenDeleteModal( user )">Delete</button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@* ──────────────────────────────── EDIT MODAL ──────────────────────────────── *@
@if ( showEditModal ) {
    <div class="modal-backdrop" @onclick="CloseModals">
        <div class="admin-modal" @onclick:stopPropagation="true">

            <div class="modal-header">
                <h2>Edit User</h2>
                <button class="modal-close" @onclick="CloseModals">✕</button>
            </div>

            <div class="modal-body">
                <EditForm Model="editModel" OnValidSubmit="SaveUser">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="form-group">
                        <label>First Name</label>
                        <InputText @bind-Value="editModel.FirstName" class="form-input" />
                    </div>

                    <div class="form-group">
                        <label>Surname</label>
                        <InputText @bind-Value="editModel.Surname" class="form-input" />
                    </div>

                    <div class="form-group">
                        <label>Username</label>
                        <InputText @bind-Value="editModel.UserName" class="form-input" />
                    </div>

                    <div class="form-group">
                        <label>Email</label>
                        <InputText @bind-Value="editModel.Email" class="form-input" />
                    </div>

                    <div class="form-group">
                        <label>Role</label>
                        <InputSelect @bind-Value="editModel.Role" class="form-input">
                            <option value="User">User</option>
                            <option value="Admin">Admin</option>
                        </InputSelect>
                    </div>

                    <div class="modal-actions">
                        <button type="button" class="btn-cancel" @onclick="CloseModals">Cancel</button>
                        <button type="submit" class="btn-confirm">Save</button>
                    </div>
                </EditForm>
            </div>

        </div>
    </div>
}

@* ──────────────────────────────── DELETE CONFIRMATION ──────────────────────────────── *@
@if ( showDeleteModal ) {
    <div class="modal-backdrop" @onclick="CloseModals">
        <div class="admin-modal" @onclick:stopPropagation="true">

            <div class="modal-header">
                <h2>Delete User</h2>
                <button class="modal-close" @onclick="CloseModals">✕</button>
            </div>

            <div class="modal-body">
                <p>Are you sure you want to delete <strong>@selectedUser?.FirstName @selectedUser?.Surname</strong>?</p>

                <div class="modal-actions">
                    <button class="btn-cancel" @onclick="CloseModals">Cancel</button>
                    <button class="btn-delete" @onclick="DeleteUser">Delete</button>
                </div>
            </div>

        </div>
    </div>
}

@code {
    private List<UserResponse>? users;

    private bool showEditModal;
    private bool showDeleteModal;

    private UserResponse? selectedUser;

    private UserEditModel editModel = new();

    protected override async Task OnInitializedAsync() {
        await LoadUsers();
    }

    private async Task LoadUsers() {
        users = await UserService.GetAllUsersAsync();
    }

    private void OpenEditModal( UserResponse user ) {
        selectedUser = user;
        editModel = new UserEditModel {
            Email = user.Email,
            UserName = user.Username,
            FirstName = user.FirstName,
            Surname = user.Surname,
            Role = user.Role
        };
        showEditModal = true;
    }

    private void OpenDeleteModal( UserResponse user ) {
        selectedUser = user;
        showDeleteModal = true;
    }

    private void CloseModals() {
        showEditModal = false;
        showDeleteModal = false;
        selectedUser = null;
    }

    private async Task SaveUser() {
        var dto = new UpdateUserDto {
            Email = editModel.Email,
            UserName = editModel.UserName,
            FirstName = editModel.FirstName,
            Surname = editModel.Surname,
            Role = editModel.Role
        };

        await UserService.UpdateUserAsync( selectedUser!.Id, dto );
        CloseModals();
        await LoadUsers();
    }

    private async Task DeleteUser() {
        await UserService.DeleteUserAsync( selectedUser!.Id );
        CloseModals();
        await LoadUsers();
    }

    public class UserEditModel {
        [Required( ErrorMessage = "First name is required." )]
        public string FirstName { get; set; } = "";

        [Required( ErrorMessage = "Surname is required." )]
        public string Surname { get; set; } = "";

        [Required( ErrorMessage = "Username is required." )]
        public string UserName { get; set; } = "";

        [Required( ErrorMessage = "Email is required." )]
        [EmailAddress( ErrorMessage = "Enter a valid email address." )]
        public string Email { get; set; } = "";

        [Required( ErrorMessage = "Role is required." )]
        public string Role { get; set; } = "User";
    }
}
