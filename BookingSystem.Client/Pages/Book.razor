@page "/book"
@using System.ComponentModel.DataAnnotations
@using BookingSystem.Shared.DTOs
@using BookingSystem.Client.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IResourceService ResourceService
@inject IBookingService BookingService

<h3>Boka Resurs</h3>
<hr />

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <EditForm Model="bookingModel" OnValidSubmit="HandleBooking">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label class="form-label">Välj resurs:</label>
                        @if (resources == null)
                        {
                            <p class="text-muted">Laddar resurser...</p>
                        }
                        else if (!resources.Any())
                        {
                            <p class="text-muted">Inga tillgängliga resurser just nu.</p>
                        }
                        else
                        {
                            <InputSelect @bind-Value="bookingModel.ResourceId" class="form-select">
                                <option value="0">-- Välj i listan --</option>
                                @foreach (var resource in resources)
                                {
                                    <option value="@resource.Id">@resource.Name</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => bookingModel.ResourceId)" class="text-danger" />
                        }
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Sällskapsstorlek:</label>
                        <InputNumber @bind-Value="bookingModel.PartySize" class="form-control" min="1" />
                        <ValidationMessage For="@(() => bookingModel.PartySize)" class="text-danger" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Anteckningar (valfritt):</label>
                        <InputTextArea @bind-Value="bookingModel.Notes" class="form-control" rows="2" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Välj datum:</label>
                        <InputDate @bind-Value="bookingModel.Date" class="form-control" />
                        <ValidationMessage For="@(() => bookingModel.Date)" class="text-danger" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Välj tid:</label>
                        <div class="d-flex align-items-center gap-2">
                            <InputSelect @bind-Value="startHour" class="form-select">
                                @for (int h = 7; h <= 21; h++)
                                {
                                    <option value="@h">@h.ToString("D2"):00</option>
                                }
                            </InputSelect>
                            <span>–</span>
                            <InputSelect @bind-Value="endHour" class="form-select">
                                @for (int h = 8; h <= 22; h++)
                                {
                                    <option value="@h">@h.ToString("D2"):00</option>
                                }
                            </InputSelect>
                        </div>
                        @if (endHour <= startHour)
                        {
                            <div class="text-danger mt-1" style="font-size:0.875rem;">
                                Sluttiden måste vara efter starttiden.
                            </div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger">@errorMessage</div>
                    }

                    <button type="submit" class="btn btn-primary w-100">Boka nu</button>
                </EditForm>
            </div>
        </div>

        @if (showSuccessMessage)
        {
            <div class="alert alert-success mt-3">
                Din bokning är genomförd!
            </div>
        }
    </div>
</div>

@code {
    private BookingModel bookingModel = new BookingModel { Date = DateTime.Now.AddDays(1) };
    private bool showSuccessMessage = false;
    private string? errorMessage;
    private int startHour = 8;
    private int endHour = 9;
    private List<ResourceDto>? resources;

    protected override async Task OnInitializedAsync()
    {
        resources = await ResourceService.GetAvailableResourcesAsync();
    }

    private async Task HandleBooking() {
        Console.WriteLine( "HandleBooking called!" );

        if ( endHour <= startHour ) return;

        try {
            var request = new CreateBookingRequest(
                StartTime: bookingModel.Date.Date.AddHours( startHour ),
                EndTime: bookingModel.Date.Date.AddHours( endHour ),
                ResourceId: bookingModel.ResourceId,
                PartySize: bookingModel.PartySize,
                Notes: bookingModel.Notes
            );

            var result = await BookingService.CreateBookingAsync( request );
            Console.WriteLine( $"Booking result: Success={result.Success}, Error={result.ErrorMessage}" );

            if ( result.Success ) {
                errorMessage = null;
                showSuccessMessage = true;
                StateHasChanged();

                await Task.Delay( 3000 );

                bookingModel = new BookingModel { Date = DateTime.Now.AddDays( 1 ) };
                startHour = 8;
                endHour = 9;
                showSuccessMessage = false;

                StateHasChanged();
            } else {
                // Show backend error if available
                errorMessage = result.ErrorMessage ?? "Bokningen misslyckades.";
            }
        } catch ( Exception ex ) {
            Console.WriteLine( $"Exception: {ex.Message}" );
            errorMessage = $"Fel: {ex.Message}";
        }
    }

    public class BookingModel
    {
        [Required(ErrorMessage = "Du måste välja en resurs från listan.")]
        public int ResourceId { get; set; }

        [Required(ErrorMessage = "Du måste välja datum.")]
        public DateTime Date { get; set; } = DateTime.Now.AddDays(1);

        [Range(1, 100, ErrorMessage = "Sällskapsstorlek måste vara minst 1.")]
        public int PartySize { get; set; } = 1;

        public string? Notes { get; set; }
    }
}