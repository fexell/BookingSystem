<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">BookingSystem.Client</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>


        <div class="nav-item px-3">
            <NavLink class="nav-link" href="login">
                <span class="bi bi-person-lock-nav-menu" aria-hidden="true"></span> Logga in
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="register">
                <span class="bi bi-person-plus-nav-menu" aria-hidden="true"></span> Registrera
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="mybookings">
                <span class="bi bi-calendar-check-nav-menu" aria-hidden="true"></span> Mina Bokningar
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="book">
                <span class="bi bi-plus-square-nav-menu" aria-hidden="true"></span> Boka
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="profile">
                <span class="bi bi-person-vcard-nav-menu" aria-hidden="true"></span> Min Profil
            </NavLink>
        </div>

    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
